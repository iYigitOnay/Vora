generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Persona {
  OBSIDIAN // Hardcore: Koyu zemin + Amber/Altın (Bodybuilding/Disiplin)
  CHARCOAL // Tech: Gece mavisi + Teal (Bilimsel veri ve analiz)
  ARCTIC   // Wellness: Beyaz/Lila + Mor (Sağlıklı yaşam ve huzur)
}

enum Gender {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY          // Masa başı iş, az veya hiç hareket
  LIGHTLY_ACTIVE     // Haftada 1-3 gün hafif spor
  MODERATELY_ACTIVE  // Haftada 3-5 gün orta tempolu spor
  VERY_ACTIVE        // Haftada 6-7 gün ağır spor
  EXTRA_ACTIVE       // Günde iki kez antrenman, fiziksel iş
}

enum Goal {
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
  GAIN_WEIGHT
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  profile   Profile?
  
  // İlişkiler
  meals     Meal[]
  waterLogs WaterLog[]
  foods     Food[]     // Kullanıcının kendi eklediği özel yiyecekler

  refreshToken String?

  @@map("users")
  @@index([email])
}

model Profile {
  id               String        @id @default(cuid())
  firstName        String
  age              Int
  gender           Gender
  height           Float
  weight           Float
  targetWeight     Float
  activityLevel    ActivityLevel
  selectedPersona  Persona       @default(CHARCOAL)
  goal             Goal

  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("profiles")
}

model Food {
  id          String   @id @default(cuid())
  name        String
  calories    Float    // 100g/ml başına
  protein     Float
  carbs       Float
  fat         Float
  barcode     String?  @unique
  brand       String?
  image       String?
  
  isGlobal    Boolean  @default(false) // Herkes görebilir mi?
  creatorId   String?
  creator     User?    @relation(fields: [creatorId], references: [id])

  mealItems   MealItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("foods")
  @@index([barcode])
  @@index([name])
}

model Meal {
  id        String     @id @default(cuid())
  type      MealType
  date      DateTime   @default(now())
  
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items     MealItem[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("meals")
  @@index([userId, date])
}

model MealItem {
  id          String   @id @default(cuid())
  amount      Float    // gram veya ml cinsinden
  customName  String?  // Kullanıcının verdiği özel isim
  note        String?  // Ekstra not (örn: "Bol tuzlu")
  
  mealId      String
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  
  foodId      String
  food        Food     @relation(fields: [foodId], references: [id])

  createdAt   DateTime @default(now())

  @@map("meal_items")
  @@index([mealId])
  @@index([foodId])
}

model WaterLog {
  id        String   @id @default(cuid())
  amount    Int      // ml cinsinden (örn: 250)
  date      DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("water_logs")
  @@index([userId, date])
}
